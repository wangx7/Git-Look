{
  "name": "git-visual",
  "displayName": "Git Look - Git 可视化",
  "description": "专注于 Git 历史检索与溯源的只读可视化工具，提供全局分支图谱、行内作者提示 (Inline Blame)、选区历史演进及文件历史比对，支持提交数据统计分析。",
  "version": "1.0.7",
  "publisher": "wangx123",
  "author": "wangx7",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wangx7/Git-Look"
  },
  "bugs": {
    "url": "https://github.com/wangx7/Git-Look/issues"
  },
  "homepage": "https://github.com/wangx7/Git-Look#readme",
  "keywords": [
    "git",
    "git graph",
    "git blame",
    "git history",
    "git visual",
    "trace",
    "blame",
    "selection history",
    "visualization"
  ],
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:git-visual.graphView",
    "onCommand:git-visual.traceOrigin",
    "onCommand:git-visual.toggleLineBlame",
    "onCommand:git-visual.traceFileHistory",
    "onCommand:git-visual.openFileRecentDiff",
    "onCommand:git-visual.showLineBlame"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-visual.traceOrigin",
        "title": "Git 选区历史"
      },
      {
        "command": "git-visual.toggleLineBlame",
        "title": "Git 行作者"
      },
      {
        "command": "git-visual.traceFileHistory",
        "title": "Git 文件历史"
      },
      {
        "command": "git-visual.openFileRecentDiff",
        "title": "Git Look: 打开最近文件 Diff"
      },
      {
        "command": "git-visual.showLineBlame",
        "title": "Git Look: 显示行作者"
      }
    ],
    "submenus": [
      {
        "id": "git-visual.submenu",
        "label": "Git Look"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "git-visual.submenu",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "git-visual.submenu": [
        {
          "command": "git-visual.toggleLineBlame",
          "group": "1_modification@1",
          "when": "editorTextFocus"
        },
        {
          "command": "git-visual.traceOrigin",
          "group": "1_modification@2",
          "when": "editorTextFocus"
        },
        {
          "command": "git-visual.traceFileHistory",
          "group": "1_modification@3",
          "when": "editorTextFocus"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "git-visual-panel",
          "title": "图谱",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "git-visual-panel": [
        {
          "type": "webview",
          "id": "git-visual.graphView",
          "name": "Git Graph"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "vsix": "vsce package",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.11.18",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.17.5",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^4.9.5"
  }
}