{
  "name": "git-visual",
  "displayName": "Git 可视化",
  "description": "选区历史、行作者、图谱",
  "version": "1.0.4",
  "publisher": "wangx123",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wangx7/Git-Look"
  },
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "activationEvents": [
    "onView:git-visual.graphView",
    "onCommand:git-visual.traceOrigin",
    "onCommand:git-visual.toggleLineBlame",
    "onCommand:git-visual.traceFileHistory",
    "onCommand:git-visual.openWorkspaceFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-visual.traceOrigin",
        "title": "Git 选区历史"
      },
      {
        "command": "git-visual.toggleLineBlame",
        "title": "Git 行作者"
      },
      {
        "command": "git-visual.traceFileHistory",
        "title": "Git 文件历史"
      },
      {
        "command": "git-visual.openWorkspaceFile",
        "title": "Git 可视化: 转到当前文件",
        "icon": "$(go-to-file)"
      }
    ],
    "submenus": [
      {
        "id": "git-visual.submenu",
        "label": "Git Look"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "git-visual.submenu",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "git-visual.submenu": [
        {
          "command": "git-visual.toggleLineBlame",
          "group": "1_modification@1",
          "when": "editorTextFocus"
        },
        {
          "command": "git-visual.traceOrigin",
          "group": "1_modification@2",
          "when": "editorTextFocus"
        },
        {
          "command": "git-visual.traceFileHistory",
          "group": "1_modification@3",
          "when": "editorTextFocus"
        }
      ],
      "editor/title": [
        {
          "command": "git-visual.openWorkspaceFile",
          "group": "navigation",
          "when": "resourceScheme == git"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "git-visual-panel",
          "title": "图谱",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "git-visual-panel": [
        {
          "type": "webview",
          "id": "git-visual.graphView",
          "name": "Git Graph"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "vsix": "vsce package",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^18.11.18",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.17.5",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^4.9.5"
  }
}
